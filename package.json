{
  "name": "bench-my-harness",
  "version": "0.1.0",
  "description": "Benchmark and observability harness for comparing agentic coding tools.",
  "type": "module",
  "bin": {
    "bench-my-harness": "./dist/adapters/inbound/cli/main.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
